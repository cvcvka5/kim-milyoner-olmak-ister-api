{
    "version": 2,
    "builds": [
      {
        "src": "api/main.js",
        "use": "@vercel/node",
        "config": {
          "nodeVersion": "22.x"
        }
      },
      {
        "src": "package.json",
        "use": "@vercel/static-build",
        "config": {
          "distDir": "dist",
          "nodeVersion": "22.x"
        }
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/main.js"
      },
      {
        "src": "/(.*)",
        "dest": "/index.html"
      }
    ]
  }